{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-ozon.local/schemas/ozon-product-draft-v1.json",
  "title": "OzonProductDraftV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_offer_id",
    "status",
    "items",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "source_offer_id": { "type": "string", "pattern": "^[0-9]+$" },
    "status": { "enum": ["completed", "needs_review", "blocked"] },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "field", "value"],
      "properties": {
        "source": {
          "enum": [
            "1688_raw",
            "canonical_v2",
            "category_decision",
            "category_attributes",
            "agent_reasoning",
            "policy"
          ]
        },
        "field": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "attributeValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "dictionary_value_id": { "type": "integer", "minimum": 1 },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "attribute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "complex_id",
        "values",
        "provenance",
        "confidence",
        "evidence"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "complex_id": { "type": "integer", "minimum": 0 },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/attributeValue" }
        },
        "provenance": {
          "enum": ["source", "converted", "agent_estimated", "derived", "default"]
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_sku_id",
        "group_id",
        "description_category_id",
        "type_id",
        "name",
        "attributes"
      ],
      "properties": {
        "source_sku_id": { "type": "string", "minLength": 1 },
        "group_id": { "type": "string", "minLength": 1 },
        "description_category_id": { "type": "integer", "minimum": 1 },
        "type_id": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/attribute" }
        }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "sku_ids", "attribute_ids"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "sku_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "attribute_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
