{
  "name": "auto-ozon-skill",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "clean": "node scripts/clean-build.mjs",
    "build": "pnpm clean && tsc -b tsconfig.build.json",
    "verify:runtime": "node scripts/verify-package-runtime.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "agent:verify": "pnpm typecheck && pnpm test && pnpm build && pnpm verify:runtime"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
