{
  "name": "auto-ozon-skill",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "clean": "node scripts/clean-build.mjs",
    "build": "pnpm clean && tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "lint": "pnpm typecheck && node scripts/static-check.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "audit:dependencies": "pnpm audit --prod --audit-level high",
    "test": "pnpm build && vitest run",
    "test:fast": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:packages": "node scripts/verify-built-packages.mjs",
    "verify:pack": "node scripts/verify-pack.mjs",
    "verify:graph": "node scripts/verify-workspace-graph.mjs",
    "agent:verify": "pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
